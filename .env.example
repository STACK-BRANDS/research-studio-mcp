# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).

# ScrapeCreators — required. Get your key at https://app.scrapecreators.com (dashboard)
SCRAPECREATORS_API_KEY=your_scrapecreators_key_here

# Apify — second Meta Ad Library source connector (run-actor + read-dataset scope).
# Create at https://console.apify.com/settings/integrations
APIFY_API_TOKEN=apify_api_your_token_here

# Gemini — optional, only for video ad analysis. https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Worker (Phase 2a) — server-side only
ANTHROPIC_API_KEY=your_anthropic_key_here
SUPABASE_URL=https://qzofnfqqvsjhsolkwnhn.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...
RESEARCH_MODEL=claude-sonnet-5

# Spend guard (worker/spend_guard.py) — hard caps on Anthropic analysis calls, persisted
# across CLI runs. Backstops the 2026-07-15 incident (13 manual re-runs, no cache/cap).
RESEARCH_ANALYSIS_MAX_PER_HOUR=20   # hard cap: analyze() calls allowed per rolling hour
RESEARCH_ANALYSIS_MAX_PER_DAY=80    # hard cap: analyze() calls allowed per rolling 24h
RESEARCH_SPEND_STATE_FILE=~/.research-studio-mcp/spend_window.json  # persisted call-timestamp window
