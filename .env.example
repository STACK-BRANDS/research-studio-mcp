# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).

# ScrapeCreators — required. Get your key at https://app.scrapecreators.com (dashboard)
SCRAPECREATORS_API_KEY=your_scrapecreators_key_here

# Gemini — optional, only for video ad analysis. https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here
